# ══════════════════════════════════════════
# TimeGrid .htaccess — Apache shared hosting
# ══════════════════════════════════════════

# Enable URL rewriting (for future SPA-style URLs if needed)
<IfModule mod_rewrite.c>
  RewriteEngine On
</IfModule>

# Default UTF-8 charset
AddDefaultCharset UTF-8

# Deny access to data directories / files
<IfModule mod_rewrite.c>
  RewriteRule ^data/ - [F,L]
  RewriteRule ^timegrid_data/ - [F,L]
</IfModule>

# Deny .json DB-like files under data/
<FilesMatch "^(db|changes)\.json$">
  Require all denied
</FilesMatch>

# Disable directory listing
Options -Indexes

# Serve correct MIME type for manifest
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
</IfModule>

# Cache policy: long for static assets, short for HTML/api
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/svg+xml "access plus 7 days"
  ExpiresByType image/png "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType text/css "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType application/manifest+json "access plus 1 day"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Service Worker must be served with no-cache so updates roll out
  <FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# PHP: ensure UTF-8 for output
<IfModule mod_php.c>
  php_value default_charset "UTF-8"
</IfModule>

# Fallback for servers without mod_php module name
<IfModule mod_php7.c>
  php_value default_charset "UTF-8"
</IfModule>
<IfModule mod_php8.c>
  php_value default_charset "UTF-8"
</IfModule>
